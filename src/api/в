    if (current === 'standart') newConfig[rowIndex][seatIndex] = 'vip';
    else if (current === 'vip') newConfig[rowIndex][seatIndex] = 'disabled';
    else newConfig[rowIndex][seatIndex] = 'standart';

    setLocalConfig(newConfig);
