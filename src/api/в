      // await api.deleteHall(hallId);
      alert(`Зал "${hallName}" был бы удалён (метод deleteHall пока не подключён)`);
      
      // После реализации api.deleteHall раскомментируй строку выше и удали alert
      await refreshData();
      
      if (selectedHallId === hallId) {
        setSelectedHallId(halls.length > 1 ? halls[0].id : null);
      }
    } catch (err: any) {
      alert('Ошибка при удалении зала: ' + (err.message || 'Неизвестная ошибка'));
    } finally {
      setIsDeleting(null);
    }
  };

  const handleSaveConfig = async () => {
    if (!selectedHall) return;

    setIsSaving(true);

    try {
      await api.updateHallConfig(selectedHall.id, rowsCount, placesCount, localConfig);
      alert('✅ Конфигурация зала успешно сохранена!');
      await refreshData();
    } catch (err: any) {
      console.error(err);
      alert('❌ Ошибка: ' + (err.message || 'Конфигурация зала не корректная'));
    } finally {
      setIsSaving(false);
    }
  };

  const handleCreateHall = async () => {
    if (!newHallName.trim()) return;

    try {
      await api.addHall(newHallName.trim());
      alert(`✅ Зал "${newHallName}" успешно создан!`);
