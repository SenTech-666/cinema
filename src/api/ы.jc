tsxКопироватьimport { useState } from 'react';
import { Seat } from '@/types';
import './HallScheme.scss';

interface HallSchemeProps {
  onSeatsChange: (seats: Seat[]) => void;
}

const HallScheme = ({ onSeatsChange }: HallSchemeProps) => {
  const [selectedSeats, setSelectedSeats] = useState<Seat[]>([]);

  // Фиксированная схема зала по твоему описанию
  const generateSeats = (): Seat[] => {
    const seats: Seat[] = [];
    const maxSeats = 12; // максимальная ширина для центрирования

    for (let row = 1; row <= 10; row++) {
      let seatsInRow = 12;

      if (row === 1) seatsInRow = 2;
      else if (row === 2) seatsInRow = 4;
      else if (row === 3) seatsInRow = 8;
      else if (row >= 4 && row <= 8) seatsInRow = 9;   // 5 + 2 + 2
      else if (row >= 9 && row <= 10) seatsInRow = 12; // 5 + 2 + 5

      // Центрирование ряда
      const offset = Math.floor((maxSeats - seatsInRow) / 2);

      for (let num = 1; num <= seatsInRow; num++) {
        const seatNumber = offset + num;

        const seat: Seat = {
          id: `${row}-${seatNumber}`,
          row,
          number: seatNumber,
          type: (row >= 4 && row <= 6) ? 'vip' : 'standard',
          status: 'free',
        };

        // Фиксированные занятые места
        if (
          (row === 5 && [6, 7].includes(seatNumber)) ||
          (row === 7 && seatNumber === 5) ||
          (row === 8 && [4, 8].includes(seatNumber))
        ) {
          seat.status = 'occupied';
        }

        seats.push(seat);
      }
    }
    return seats;
  };

  const seats = generateSeats();

  const toggleSeat = (seat: Seat) => {
    if (seat.status === 'occupied') return;

    let newSelected: Seat[];
    if (selectedSeats.some(s => s.id === seat.id)) {
      newSelected = selectedSeats.filter(s => s.id !== seat.id);
    } else {
      newSelected = [...selectedSeats, seat];
    }

    setSelectedSeats(newSelected);
    onSeatsChange(newSelected);
  };

  // Группируем места по рядам для правильного отображения
  const seatsByRow = seats.reduce((acc, seat) => {
    if (!acc[seat.row]) acc[seat.row] = [];
    acc[seat.row].push(seat);
    return acc;
  }, {} as Record<number, Seat[]>);

  return (
    <div className="hall-scheme">
      <div className="hall-scheme__screen">ЭКРАН</div>

      <div className="hall-scheme__rows">
        {Object.keys(seatsByRow).map((rowNum) => {
          const rowSeats = seatsByRow[parseInt(rowNum)];
          return (
            <div key={rowNum} className="hall-row">
              <div className="row-number">{rowNum}</div>
              <div className="hall-row__seats">
                {rowSeats.map((seat) => {
                  const isSelected = selectedSeats.some(s => s.id === seat.id);
                  return (
                    <button
                      key={seat.id}
                      className={`seat seat--${seat.type} seat--${seat.status} ${isSelected ? 'seat--selected' : ''}`}
                      onClick={() => toggleSeat(seat)}
                      disabled={seat.status === 'occupied'}
                    >
                      {seat.number}
                    </button>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>

      <div className="hall-scheme__legend">
        <div className="legend-item">
          <span className="seat seat--standard seat--free"></span>
          <span>Свободно (250 ₽)</span>
        </div>
        <div className="legend-item">
          <span className="seat seat--vip seat--free"></span>
          <span>Свободно VIP (350 ₽)</span>
        </div>
        <div className="legend-item">
          <span className="seat seat--occupied"></span>
          <span>Занято</span>
        </div>
        <div className="legend-item">
          <span className="seat seat--selected"></span>
          <span>Выбрано</span>
        </div>
      </div>
    </div>
  );
};

export default HallScheme;
