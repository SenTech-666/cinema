src/pages/Guest/Booking/Booking.tsx
tsximport { useLocation, useNavigate } from 'react-router-dom';
import QRCode from 'qrcode.react';
import { useState } from 'react';
import './Booking.scss';
interface Seat {
  row: number;
  number: number;
  type: 'standard' | 'vip';
}
interface BookingData {
  sessionId: string;
  movieTitle: string;
  time: string;
  hall: string;
  date: string;
  selectedSeats: Seat[];
  totalPrice: number;
}
const Booking = () => {
  const location = useLocation();
  const navigate = useNavigate();
  const bookingData = location.state as BookingData | null;
  const [isSaved, setIsSaved] = useState(false);
  if (!bookingData) {
    return <div className="container py-5">Ошибка: данные бронирования не найдены</div>;
  }
  const { movieTitle, time, hall, date, selectedSeats, totalPrice, sessionId } = bookingData;
  const bookingCode = BK-${Date.now().toString(36).toUpperCase()};
  const ticketData = {
    code: bookingCode,
    movie: movieTitle,
    date,
    time,
    hall,
    seats: selectedSeats.map(s => Ряд ${s.row}, место ${s.number}).join('; '),
    price: totalPrice,
    note: "Билет действителен строго на свой сеанс"
  };
  const handleSaveTicket = () => {
    const savedTickets = JSON.parse(localStorage.getItem('savedTickets') || '[]');
    savedTickets.push(ticketData);
    localStorage.setItem('savedTickets', JSON.stringify(savedTickets));
   
    setIsSaved(true);
    alert('Билет успешно сохранён! Вы можете посмотреть его в разделе "Мои билеты" (будет добавлен позже)');
  };
  return (
    <div className="booking-page"><div className="container py-5"><div className="booking-page__header text-center mb-5"><h1 className="booking-page__title">Ваш билет</h1><p className="text-muted">Проверьте информацию перед сохранением</p></div><div className="row justify-content-center"><div className="col-lg-8"><div className="card shadow booking-card"><div className="card-body p-4">                {/* Информация о сеансе */}
                <div className="booking-info">
                  <h2 className="booking-info__movie">{movieTitle}</h2>
                  <p className="booking-info__details">
                    {date} • {time} • Зал {hall}
                  </p>
                </div>
                {/* Места */}
                <div className="seats-info mb-4">
                  <h5>Выбранные места:</h5>
                  <div className="seats-list">
                    {selectedSeats.map((seat, index) => (
                      <span key={index} className="seat-badge">
                        Ряд {seat.row}, место {seat.number}
                        {seat.type === 'vip' && <span className="vip-badge">VIP</span>}
                      </span>
                    ))}
                  </div>
                </div>
                {/* Стоимость */}
                <div className="price-info mb-4">
                  <div className="d-flex justify-content-between align-items-center">
                    <span className="fs-5">Итого к оплате:</span>
                    <span className="fs-3 fw-bold text-success">{totalPrice} ₽</span>
                  </div>
                </div>
                {/* QR-код */}
                <div className="qr-section text-center my-4">
                  <h5>QR-код билета</h5>
                  <div className="qr-container mx-auto">
                    <QRCode
                      value={JSON.stringify(ticketData)}
                      size={220}
                      level="H"
                      includeMargin={true}
                    />
                  </div>
                  <small className="text-muted d-block mt-2">
                    Сохраните или распечатайте билет
                  </small>
                </div>
                {/* Важная фраза */}
                <div className="note text-center mb-4">
                  <strong>Билет действителен строго на свой сеанс</strong>
                </div>
                {/* Кнопки */}
                <div className="d-flex gap-3 justify-content-center">                  <button
                    className="btn btn-outline-secondary btn-lg px-4"
                    onClick={() => navigate('/')}
                  >
                    Вернуться на главную
                  </button>                 
                  <button
                    className="btn btn-success btn-lg px-5"
                    onClick={handleSaveTicket}
                    disabled={isSaved}
                  >
                    {isSaved ? '✓ Билет сохранён' : 'Сохранить билет'}
                  </button></div></div></div></div></div></div></div>  );
};
export default Booking;
