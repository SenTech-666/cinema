.home {
  min-height: 100vh;
  background-image: url('../../../assets/img/desktop.jpg');
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  position: relative;

  /* ====================== HEADER ====================== */
  &__header {
    padding: 20px 0;
    position: relative;
    z-index: 2;
  }

  &__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 2.4rem;
    font-weight: 900;
    color: #2c2c2c;
    margin: 0;
  }

  /* ====================== БЛОК ДАТ ====================== */
  .date-picker {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 8px;
    padding: 6px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    width: fit-content;
  }

  .date-item {
    padding: 12px 18px;
    border-radius: 6px;
    font-weight: 500;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s ease;
    min-width: 125px;
    font-size: 1rem;

    &.active {
      background: #2c2c2c;
      color: white;
      min-width: 241px;
      font-weight: 600;
    }

    /* Суббота — красный цвет */
    &.saturday {
      color: #e74c3c;
    }

    &.saturday.active {
      color: white;
    }
  }

  .arrow {
    min-width: 48px !important;
    padding: 12px 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    color: #2c2c2c;

    &:hover {
      background: #f5c518;
      color: #1a1a1a;
    }
  }

  /* ====================== КОНТЕНТ ====================== */
  &__content {
    padding: 40px 0;
    position: relative;
    z-index: 2;
  }
}

/* ====================== КАРТОЧКА ФИЛЬМА ====================== */
.movie-row {
  display: flex;
  gap: 32px;
  background: #fff;
  margin-bottom: 40px;
  border-radius: 12px;
  padding: 15px;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);

  &__poster {
    width: 300px;
    flex-shrink: 0;

    img {
      width: 125px;
      height: 175px;
      object-fit: cover;
    }
  }

  &__info {
    padding: 32px 28px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  &__title {
    font-size: 1.85rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: #2c2c2c;
  }

  &__meta {
    color: #666;
    font-size: 1.05rem;
    margin-bottom: 28px;
  }
}

/* ====================== БЛОКИ СЕАНСОВ ====================== */
.home-seance-blocks {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-top: 12px;
}

.home-seance-block {
  
  &__title {
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 12px;
    color: #2c2c2c;
  }
}

.home-seance-times {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.home-time {
  background: #ffffff;
  padding: 10px 18px;
  border-radius: 8px;
  font-size: 0.97rem;
  font-weight: 500;
  cursor: pointer;
  border: 1px solid #e0e0e0;
  transition: all 0.25s ease;

  &:hover {
    background: #f5c518;
    border-color: #f5c518;
    color: #1a1a1a;
    transform: translateY(-1px);
  }
}

.no-seances {
  color: #888;
  font-style: italic;
  padding: 12px 0;
}

/* ====================== Состояния ====================== */
.loading,
.error {
  text-align: center;
  padding: 100px 20px;
  font-size: 1.25rem;
  color: #555;
}

.error {
  color: #e74c3c;
