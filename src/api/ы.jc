.home {
  min-height: 100vh;
  background-image: url('../../assets/img/desktop.jpg');
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  position: relative;

  &__header {
    padding: 20px 0;
  }

  &__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 2.4rem;
    font-weight: 900;
    color: #2c2c2c;
    margin: 0;
  }

  .date-picker {
    display: flex;
    gap: 8px;
    margin-top: 20px;
  }

  .date-item {
    padding: 10px 18px;
    background: white;
    border-radius: 6px;
    font-weight: 500;
    cursor: pointer;

    &.active {
      background: #2c2c2c;
      color: white;
    }
  }

  &__content {
    padding: 40px 0;
  }
}

.movie-row {
  display: flex;
  gap: 30px;
  background: white;
  margin-bottom: 30px;
