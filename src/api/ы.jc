                    {/* Зал 1 */}
                    <div className="hall-section">
                      <div className="hall-title">Зал 1</div>
                      <div className="time-buttons">
                        {movie.currentSessions
                          .filter(s => s.hall === 1)
                          .map((session, i) => (
