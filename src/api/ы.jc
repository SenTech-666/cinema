      newSelected = selectedSeats.filter(id => id !== seatId);
    } else {
      newSelected = [...selectedSeats, seatId];
    }
    setSelectedSeats(newSelected);
    onSeatsChange(newSelected);
  };
  // ... остальной return без изменений
Готово.
