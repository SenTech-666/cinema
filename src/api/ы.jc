tsximport { useState } from 'react';
import { useNavigate } from 'react-router-dom';
import Header from '../../components/Header/Header';
import './Home.scss';
interface Movie {
  id: number;
  title: string;
  poster: string;
  genre: string;
  duration: string;
  rating: string;
  sessionId: string;
}
const mockMovies: Movie[] = [
  {
    id: 1,
    title: "Звёздные войны XXIII: Атака клонов",
    poster: "https://via.placeholder.com/300x400/1a1a1a/ffffff?text=Star+Wars",
    genre: "Фантастика",
    duration: "142 мин",
    rating: "16+",
    sessionId: "sw-1830",
  },
  {
    id: 2,
    title: "Мстители: Финал",
    poster: "https://via.placeholder.com/300x400/1a1a1a/ffffff?text=Avengers",
    genre: "Боевик",
    duration: "181 мин",
    rating: "16+",
    sessionId: "av-2030",
  },
  {
    id: 3,
    title: "Дюна: Часть вторая",
    poster: "https://via.placeholder.com/300x400/1a1a1a/ffffff?text=Dune",
    genre: "Фантастика",
    duration: "166 мин",
    rating: "16+",
    sessionId: "dune-2100",
  },
];
const Home = () => {
  const navigate = useNavigate();
  const [movies] = useState(mockMovies);
  const goToHall = (sessionId: string) => {
    navigate(/hall/${sessionId});
  };
  return (
    <>
      <Header />
      <div className="home">
        {/* Hero секция — теперь фон будет покрывать всю страницу */}
        <section className="home__hero">
          <div className="container">
            <div className="home__hero-content">
              <h1 className="home__title">ИДЁМ В КИНО</h1>
              <p className="home__subtitle">Бронируй билеты онлайн — быстро и удобно</p>
            </div>
          </div>
        </section>
        {/* Афиша сегодня */}
        <section className="home__afisha">
          <div className="container">
            <h2 className="section-title">Сегодня в кино</h2>
            <div className="movies-grid">
              {movies.map((movie) => (
                <div
                  key={movie.id}
                  className="movie-card"
                  onClick={() => goToHall(movie.sessionId)}
                  style={{ cursor: 'pointer' }}
                >
                  <div className="movie-card__poster">
                    <img src={movie.poster} alt={movie.title} />
                    <div className="movie-card__rating">{movie.rating}</div>
                  </div>
                  <div className="movie-card__info">
                    <h3 className="movie-card__title">{movie.title}</h3>
                    <p className="movie-card__genre">{movie.genre} • {movie.duration}</p>
                    <button className="btn btn-primary w-100 mt-3">
                      Выбрать места
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      </div>
    </>
  );
};
export default Home;
3.2. src/pages/Guest/Hall/Hall.tsx
Замени полностью:
tsximport { useState } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import Header from '../../../components/Header/Header';
import HallScheme from '../../components/HallScheme/HallScheme';
import { Seat } from '@/types';
import './Hall.scss';
const Hall = () => {
  const { sessionId } = useParams();
  const navigate = useNavigate();
  const [selectedSeats, setSelectedSeats] = useState<Seat[]>([]);
  const STANDARD_PRICE = 250;
  const VIP_PRICE = 350;
  const totalPrice = selectedSeats.reduce((sum, seat) =>
    sum + (seat.type === 'vip' ? VIP_PRICE : STANDARD_PRICE), 0);
  const handleSeatsChange = (seats: Seat[]) => {
    setSelectedSeats(seats);
  };
  const handleBook = () => {
    if (selectedSeats.length === 0) return;
    navigate('/booking', {
      state: {
        sessionId: sessionId || '',
        movieTitle: "Звёздные войны XXIII: Атака клонов",
        time: "18:30",
        hall: "1",
        date: "Сегодня",
        selectedSeats,
        totalPrice
      }
    });
  };
  return (
    <>
      <Header />
      <div className="hall-page">
        <div className="container py-5">
          <div className="hall-page__info text-center mb-5">
            <h1>Звёздные войны XXIII: Атака клонов</h1>
            <p>Начало сеанса: <strong>18:30</strong> • Зал 1 • {sessionId}</p>
          </div>
          <div className="hall-page__content mb-5">
            <HallScheme onSeatsChange={handleSeatsChange} />
          </div>
          <div className="hall-page__actions text-center">
            <div className="selected-info fs-4 mb-4">
              Выбрано мест: <strong>{selectedSeats.length}</strong> •
              Сумма: <strong>{totalPrice} ₽</strong>
            </div>
            <button
              className="btn btn-success btn-lg px-5"
              onClick={handleBook}
              disabled={selectedSeats.length === 0}
            >
              ЗАБРОНИРОВАТЬ
            </button>
          </div>
        </div>
      </div>
    </>
  );
};
export default Hall;
3.3. src/pages/Guest/Booking/Booking.tsx
Замени полностью:
tsximport { useLocation, useNavigate } from 'react-router-dom';
import QRCode from 'qrcode.react';
import { useState } from 'react';
import { BookingData } from '@/types';
import Header from '../../../components/Header/Header';
import './Booking.scss';
const Booking = () => {
  const location = useLocation();
  const navigate = useNavigate();
  const bookingData = location.state as BookingData | null;
  const [isSaved, setIsSaved] = useState(false);
  if (!bookingData) {
    return (
      <>
        <Header />
        <div className="container py-5">Ошибка: данные бронирования не найдены</div>
      </>
    );
  }
  const { movieTitle, time, hall, date, selectedSeats, totalPrice, sessionId } = bookingData;
  const bookingCode = BK-${Date.now().toString(36).toUpperCase()};
  const ticketData = {
    code: bookingCode,
    movie: movieTitle,
    date,
    time,
    hall,
    seats: selectedSeats.map(s => Ряд ${s.row}, место ${s.number}).join('; '),
    price: totalPrice,
    note: "Билет действителен строго на свой сеанс"
  };
  const handleSaveTicket = () => {
    const savedTickets = JSON.parse(localStorage.getItem('savedTickets') || '[]');
    savedTickets.push(ticketData);
    localStorage.setItem('savedTickets', JSON.stringify(savedTickets));
    setIsSaved(true);
    alert('Билет успешно сохранён!');
  };
  return (
    <>
      <Header />
      <div className="booking-page">
        <div className="container py-5">
          <div className="booking-page__header text-center mb-5">
            <h1 className="booking-page__title">Ваш билет</h1>
            <p className="text-muted">Проверьте информацию перед сохранением</p>
          </div>
          <div className="row justify-content-center">
            <div className="col-lg-8">
              <div className="card shadow booking-card">
                <div className="card-body p-4">
                  <div className="booking-info">
                    <h2 className="booking-info__movie">{movieTitle}</h2>
                    <p className="booking-info__details">
                      {date} • {time} • Зал {hall}
                    </p>
                  </div>
                  <div className="seats-info mb-4">
                    <h5>Выбранные места:</h5>
                    <div className="seats-list">
                      {selectedSeats.map((seat, index) => (
                        <span key={index} className="seat-badge">
                          Ряд {seat.row}, место {seat.number}
                          {seat.type === 'vip' && <span className="vip-badge">VIP</span>}
                        </span>
                      ))}
                    </div>
                  </div>
                  <div className="price-info mb-4">
                    <div className="d-flex justify-content-between align-items-center">
                      <span className="fs-5">Итого к оплате:</span>
                      <span className="fs-3 fw-bold text-success">{totalPrice} ₽</span>
                    </div>
                  </div>
                  <div className="qr-section text-center my-4">
                    <h5>QR-код билета</h5>
                    <div className="qr-container mx-auto">
                      <QRCode
                        value={JSON.stringify(ticketData)}
                        size={220}
                        level="H"
                        includeMargin={true}
                      />
                    </div>
                  </div>
                  <div className="note text-center mb-4">
                    <strong>Билет действителен строго на свой сеанс</strong>
                  </div>
                  <div className="d-flex gap-3 justify-content-center">
                    <button
                      className="btn btn-outline-secondary btn-lg px-4"
                      onClick={() => navigate('/')}
                    >
                      Вернуться на главную
                    </button>
                    <button
                      className="btn btn-success btn-lg px-5"
                      onClick={handleSaveTicket}
                      disabled={isSaved}
                    >
                      {isSaved ? '✓ Билет сохранён' : 'Сохранить билет'}
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </>
  );
};
export default Booking;
