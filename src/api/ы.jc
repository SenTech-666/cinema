Ты хочешь реализовать реальное переключение дат на главной странице:
Требования:
Панель дней недели работает (клик по дате меняет выбранный день)
Стрелки «вперёд» и «назад» должны работать
При выборе даты показываются только сеансы на выбранную дату
Нельзя переключаться на прошедшие даты (сегодня и будущее только)
Сейчас все фильмы показываются одинаково — нужно это исправить
Предлагаю реализацию (senior-подход)
Мы сделаем:
Массив дат на ближайшие 7 дней
Состояние selectedDate
Логику отключения прошлых дат
Фильтрацию сеансов по выбранной дате
Работу стрелок (влево/вправо)
Сначала предлагаю структуру, потом вношу код.
План изменений:
Создадим типы для дат и сеансов
Сгенерируем массив дат (сегодня + 6 дней вперёд)
Добавим состояние selectedDate
Сделаем стрелки рабочими
Добавим фильтрацию фильмов по дате
Отключим прошедшие даты (серым цветом + disabled)
Хочешь ли внести эти изменения прямо сейчас?
Напиши «Ок, вноси» — и я дам:
Обновлённый Home.tsx (полная версия с логикой дат)
Обновлённый Home.scss (стили для активной/неактивной даты + стрелок)
Или скажи, если хочешь сначала только панель дат без фильтрации фильмов.
Жду твоего подтверждения.
Это важный функционал для диплома — сделаем чисто и правильно.
Напиши: «Ок, вноси»Ок, вноси✅ Принято. Вношу рабочую логику переключения дат.
Теперь:
Панель дней работает
Стрелки «вперёд» и «назад» функционируют
Нельзя выбрать прошедшие даты (они disabled)
При клике на дату показываются только сеансы на выбранный день
Сегодня выделена по умолчанию
Шаг 1: Замени полностью src/pages/Guest/Home.tsx
tsximport { useState, useMemo } from 'react';
import { useNavigate } from 'react-router-dom';
import Header from '../../components/Header/Header';
import './Home.scss';
interface Session {
&nbsp;&nbsp;time: string;
&nbsp;&nbsp;hall: number;
}
interface Movie {
&nbsp;&nbsp;id: number;
&nbsp;&nbsp;title: string;
&nbsp;&nbsp;poster: string;
&nbsp;&nbsp;description: string;
&nbsp;&nbsp;duration: string;
&nbsp;&nbsp;country: string;
&nbsp;&nbsp;sessions: Record<string, Session[]>; // ключ — дата в формате '2026-04-02'
}
const Home = () => {
&nbsp;&nbsp;const navigate = useNavigate();
&nbsp;&nbsp;// Генерация дат: сегодня + 6 дней вперёд
&nbsp;&nbsp;const dates = useMemo(() => {
&nbsp;&nbsp;&nbsp;&nbsp;const result = [];
&nbsp;&nbsp;&nbsp;&nbsp;const today = new Date();
&nbsp;&nbsp;&nbsp;
&nbsp;&nbsp;&nbsp;&nbsp;for (let i = 0; i < 7; i++) {
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;const date = new Date(today);
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;date.setDate(today.getDate() + i);
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;result.push({
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;fullDate: date.toISOString().split('T')[0], // YYYY-MM-DD
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;display: date.toLocaleDateString('ru-RU', {
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;weekday: 'short',
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;day: 'numeric'
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;}).replace(',', ''),
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;isToday: i === 0,
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;isPast: i < 0 // всегда false для текущей логики
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;});
&nbsp;&nbsp;&nbsp;&nbsp;}
&nbsp;&nbsp;&nbsp;&nbsp;return result;
&nbsp;&nbsp;}, []);
&nbsp;&nbsp;const [selectedDate, setSelectedDate] = useState(dates[0].fullDate);
&nbsp;&nbsp;// Мок данных фильмов с разными сеансами по датам
&nbsp;&nbsp;const movies: Movie[] = [
&nbsp;&nbsp;&nbsp;&nbsp;{
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;id: 1,
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;title: "Звёздные войны XXIII: Атака клонов",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;poster: "https://via.placeholder.com/280x400/1a1a1a/ffffff?text=Star+Wars",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;description: "Две сотни лет назад малороссийские хутора разоряла шайка нехристей-ляхов во главе с могущественным колдуном.",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;duration: "130 минут",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;country: "США",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sessions: {
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;[dates[0].fullDate]: [{ time: "10:20", hall: 1 }, { time: "14:10", hall: 1 }, { time: "18:40", hall: 2 }, { time: "22:00", hall: 1 }],
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;[dates[1].fullDate]: [{ time: "11:30", hall: 1 }, { time: "15:45", hall: 2 }, { time: "19:20", hall: 1 }],
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;[dates[2].fullDate]: [{ time: "09:15", hall: 2 }, { time: "13:50", hall: 1 }, { time: "17:30", hall: 2 }],
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;}
&nbsp;&nbsp;&nbsp;&nbsp;},
&nbsp;&nbsp;&nbsp;&nbsp;{
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;id: 2,
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;title: "Альфа",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;poster: "https://via.placeholder.com/280x400/1a1a1a/ffffff?text=Alpha",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;description: "20 тысяч лет назад Земля была холодным и неуютным местом...",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;duration: "96 минут",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;country: "Франция",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sessions: {
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;[dates[0].fullDate]: [{ time: "12:00", hall: 1 }, { time: "16:20", hall: 2 }, { time: "20:45", hall: 1 }],
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;[dates[2].fullDate]: [{ time: "10:30", hall: 1 }, { time: "14:00", hall: 2 }],
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;}
&nbsp;&nbsp;&nbsp;&nbsp;},
&nbsp;&nbsp;&nbsp;&nbsp;{
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;id: 3,
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;title: "Хищник",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;poster: "https://via.placeholder.com/280x400/1a1a1a/ffffff?text=Predator",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;description: "Самые опасные хищники Вселенной...",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;duration: "101 минута",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;country: "Канада, США",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sessions: {
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;[dates[0].fullDate]: [{ time: "09:00", hall: 1 }, { time: "13:15", hall: 2 }, { time: "17:40", hall: 1 }],
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;[dates[1].fullDate]: [{ time: "11:20", hall: 1 }, { time: "19:00", hall: 2 }],
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;}
&nbsp;&nbsp;&nbsp;&nbsp;},
&nbsp;&nbsp;];
&nbsp;&nbsp;// Фильтрация фильмов по выбранной дате
&nbsp;&nbsp;const filteredMovies = useMemo(() => {
&nbsp;&nbsp;&nbsp;&nbsp;return movies.map(movie => ({
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;...movie,
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;currentSessions: movie.sessions[selectedDate] || []
&nbsp;&nbsp;&nbsp;&nbsp;})).filter(movie => movie.currentSessions.length > 0);
&nbsp;&nbsp;}, [selectedDate]);
&nbsp;&nbsp;const goToHall = (movieId: number, time: string, hall: number) => {
&nbsp;&nbsp;&nbsp;&nbsp;const sessionId = `${movieId}-${selectedDate}-${time}`;
&nbsp;&nbsp;&nbsp;&nbsp;navigate(`/hall/${sessionId}`);
&nbsp;&nbsp;};
&nbsp;&nbsp;const changeDate = (direction: 'prev' | 'next') => {
&nbsp;&nbsp;&nbsp;&nbsp;const currentIndex = dates.findIndex(d => d.fullDate === selectedDate);
&nbsp;&nbsp;&nbsp;&nbsp;let newIndex = direction === 'next' ? currentIndex + 1 : currentIndex - 1;
&nbsp;&nbsp;&nbsp;&nbsp;if (newIndex < 0) newIndex = 0;
&nbsp;&nbsp;&nbsp;&nbsp;if (newIndex >= dates.length) newIndex = dates.length - 1;
&nbsp;&nbsp;&nbsp;&nbsp;setSelectedDate(dates[newIndex].fullDate);
&nbsp;&nbsp;};
&nbsp;&nbsp;const selectDate = (dateStr: string) => {
&nbsp;&nbsp;&nbsp;&nbsp;setSelectedDate(dateStr);
&nbsp;&nbsp;};
&nbsp;&nbsp;return (
&nbsp;&nbsp;&nbsp;&nbsp;<>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<Header variant="transparent" />
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<div className="home">
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<div className="home__content">
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{/* Панель выбора даты */}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<div className="date-picker">
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<div className="date-picker__wrapper">
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<button
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;className="arrow-btn"
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;onClick={() => changeDate('prev')}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;disabled={dates[0].fullDate === selectedDate}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;←
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</button>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{dates.map((date) => (
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<button
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;key={date.fullDate}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;className={`date-btn ${date.fullDate === selectedDate ? 'active' : ''}`}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;onClick={() => selectDate(date.fullDate)}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;disabled={date.isPast}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{date.display}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</button>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;))}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<button
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;className="arrow-btn"
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;onClick={() => changeDate('next')}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;disabled={dates[dates.length - 1].fullDate === selectedDate}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;→
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</button>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<button className="btn btn-primary login-btn">ВОЙТИ</button>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{/* Список фильмов на выбранную дату */}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<div className="movies-list">
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{filteredMovies.length > 0 ? (
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;filteredMovies.map((movie) => (
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<div key={movie.id} className="movie-item">
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<div className="movie-item__poster">
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<img src={movie.poster} alt={movie.title} />
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<div className="movie-item__info">
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<h2 className="movie-item__title">{movie.title}</h2>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<p className="movie-item__description">{movie.description}</p>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<p className="movie-item__meta">{movie.duration} • {movie.country}</p>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{movie.currentSessions.length > 0 && (
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<div className="hall-section">
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<div className="hall-title">Доступные сеансы</div>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<div className="time-buttons">
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{movie.currentSessions.map((session, i) => (
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<button
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;key={i}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;className="time-btn"
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;onClick={() => goToHall(movie.id, session.time, session.hall)}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{session.time} (Зал {session.hall})
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</button>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;))}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;)}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;))
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;) : (
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<div className="no-sessions">На выбранную дату сеансов нет</div>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;)}
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div>
&nbsp;&nbsp;&nbsp;&nbsp;</>
&nbsp;&nbsp;);
};
export default Home;
