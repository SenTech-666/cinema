    border-color: #555;
    color: transparent;
    cursor: not-allowed;
  }

  &--selected {
    background: #00bfff !important;
    color: white;
    border-color: #00e0ff;
    box-shadow: 0 0 0 4px rgba(0, 191, 255, 0.45);
    transform: scale(1.08);
  }

  &:hover:not(.seat--occupied):not(.seat--blocked):not(.seat--selected) {
    transform: scale(1.12);
  }
}

