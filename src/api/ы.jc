  transition: all 0.25s ease;

  &:hover {
    background: #f5c518;
    border-color: #f5c518;
    color: #1a1a1a;
    transform: translateY(-1px);
  }
}

.no-seances {
  color: #888;
  font-style: italic;
  padding: 12px 0;
}

/* ====================== Состояния ====================== */
.loading,
.error {
  text-align: center;
  padding: 100px 20px;
  font-size: 1.25rem;
  color: #555;
}

.error {
  color: #e74c3c;
}
2. Полностью замени src/pages/Guest/Home/Home.tsx
import { useApi } from '../../context/ApiContext';
import { useNavigate } from 'react-router-dom';
import './Home.scss';

const Home = () => {
  const { movies, seances, halls, loading, error, refreshData } = useApi();
  const navigate = useNavigate();

  const handleSeanceClick = (seanceId: number) => {
    navigate(`/hall/${seanceId}`);
  };

  const getHallName = (hallId: number): string => {
    const hall = halls.find((h) => h.id === hallId);
    return hall ? hall.hall_name : `Зал ${hallId}`;
  };

  if (loading) {
    return (
      <div className="home">
        <div className="container py-5 text-center">
          <h2>Загрузка афиши...</h2>
        </div>
      </div>
    );
  }

  if (error) {
    return (
      <div className="home">
        <div className="container py-5 text-center text-danger">
          <h2>Ошибка загрузки</h2>
          <p>{error}</p>
          <button className="btn btn-primary mt-3" onClick={refreshData}>
            Попробовать снова
          </button>
        </div>
      </div>
    );
  }

  return (
    <div className="home">
      {/* Header */}
      <header className="home__header">
        <div className="container">
          <div className="home__top">
            <h1 className="logo">ИДЁМВКИНО</h1>
            <button className="btn btn-primary">ВОЙТИ</button>
          </div>

          <div className="date-picker">
            <div className="date-item active">Сегодня</div>
            <div className="date-item">Вт</div>
            <div className="date-item">Ср</div>
            <div className="date-item">Чт</div>
            <div className="date-item">Пт</div>
            <div className="date-item">Сб</div>
          </div>
        </div>
      </header>

      {/* Список фильмов */}
      <div className="home__content">
        <div className="container">
          {movies.length > 0 ? (
            movies.map((movie) => {
              const movieSeances = seances.filter((s) => s.seance_filmid === movie.id);

              // Группируем сеансы по залам
              const seancesByHall: Record<number, any[]> = {};
              movieSeances.forEach((seance) => {
                if (!seancesByHall[seance.seance_hallid]) {
                  seancesByHall[seance.seance_hallid] = [];
                }
                seancesByHall[seance.seance_hallid].push(seance);
              });

              return (
                <div key={movie.id} className="movie-row">
                  {/* Постер */}
                  <div className="movie-row__poster">
                    <img
                      src={movie.film_poster || "https://via.placeholder.com/300x420/1a1a1a/ffffff?text=Постер"}
                      alt={movie.film_name}
                    />
                  </div>

                  {/* Информация о фильме + сеансы */}
                  <div className="movie-row__info">
                    <h2 className="movie-row__title">{movie.film_name}</h2>
                    <p className="movie-row__meta">
                      {movie.film_duration} мин • {movie.film_origin || '—'}
                    </p>

                    {/* Блоки по залам */}
                    <div className="home-seance-blocks">
                      {Object.entries(seancesByHall).map(([hallIdStr, hallSeances]) => {
                        const hallId = Number(hallIdStr);
                        const hallName = getHallName(hallId);

                        return (
                          <div key={hallId} className="home-seance-block">
                            <div className="home-seance-block__title">{hallName}</div>

                            <div className="home-seance-times">
                              {hallSeances.map((seance) => (
                                <span
                                  key={seance.id}
                                  className="home-time"
                                  onClick={() => handleSeanceClick(seance.id)}
                                >
                                  {seance.seance_time}
                                </span>
                              ))}
                            </div>
                          </div>
                        );
                      })}

                      {movieSeances.length === 0 && (
                        <p className="no-seances">Сеансы пока не назначены</p>
                      )}
                    </div>
                  </div>
                </div>
              );
            })
          ) : (
            <div className="text-center py-5">
              <p>На данный момент нет доступных фильмов</p>
            </div>
          )}
        </div>
      </div>
    </div>
  );
};

export default Home;
