Шаг 1: Обновляем Header (добавляем проп variant)
Замени полностью:
src/components/Header/Header.tsx
tsximport { NavLink } from 'react-router-dom';
import './Header.scss';
interface HeaderProps {
  variant?: 'dark' | 'transparent'; // dark — обычный, transparent — для главной
}
const Header = ({ variant = 'dark' }: HeaderProps) => {
  const isTransparent = variant === 'transparent';
  return (
    <header className={header ${isTransparent ? 'header--transparent' : ''}}>
      <div className="container">
        <div className="header__inner">
          <div className="header__logo">
            <h1>ИДЁМ<span>ВКИНО</span></h1>
          </div>
          <nav className="header__nav">
            <NavLink
              to="/"
              className="header__link"
              end
            >
              Афиша
            </NavLink>
            <NavLink
              to="/tickets"
              className="header__link"
            >
              Билеты
            </NavLink>
            <NavLink
              to="/admin"
              className="header__link"
            >
              Админка
            </NavLink>
          </nav>
        </div>
      </div>
    </header>
  );
};
export default Header;
