      const dayNumber = date.getDate();

      result.push({
        fullDate: date.toISOString().split('T')[0],
        display: `${dayName}, ${dayNumber}`,
        isSaturday: date.getDay() === 6,
        isToday: i === 0,
      });
    }
    return result;
  }, []);

  const selectedDate = dates[selectedDateIndex];

  // ==================== Фильтрация сеансов ====================
