.home__content {
  position: relative;
  z-index: 2;
  max-width: 1164px;
  margin: 0 auto;
  padding: 30px 20px 80px;
}

/* Панель дат */
.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40px;
  background: rgba(255, 255, 255, 0.92);
  padding: 16px 20px;
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
}

.date-picker__wrapper {
  display: flex;
  gap: 4px;
}

.date-btn {
  background: rgba(255, 255, 255, 0.92);
  border: 2px solid #ddd;
  color: #333;
  padding: 12px 20px;
  font-size: 0.95rem;
  min-width: 110px;
  transition: all 0.2s;

  &.active {
    background: #f5c518;
    border-color: #f5c518;
    color: #1a1a1a;
    font-weight: 600;
  }
}

.login-btn {
  padding: 12px 32px;
  font-weight: 600;
}

/* Карточка фильма — белый прямоугольник без скруглений */
.movie-item {
  display: flex;
  background: #ffffff;
  border: 1px solid #e0e0e0;
  padding: 0;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);

  &__poster {
    width: 300px;
    flex-shrink: 0;
    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
  }

  &__info {
    flex: 1;
    padding: 32px 40px 32px 36px;
    display: flex;
    flex-direction: column;
  }

  &__title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: #2c2c2c;
  }

  &__description {
    color: #555;
    line-height: 1.55;
    margin-bottom: 24px;
    flex-grow: 1;
  }

  &__meta {
    color: #666;
    margin-bottom: 28px;
    font-size: 1.05rem;
  }
}

/* Залы */
.hall-section {
  margin-bottom: 28px;

  .hall-title {
    font-weight: 600;
    margin-bottom: 10px;
    color: #2c2c2c;
    font-size: 1.1rem;
  }
}

.time-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.time-btn {
  background: #ffffff;
  border: 1px solid #ccc;
  padding: 10px 22px;
  font-size: 0.98rem;
  transition: all 0.2s;

  &:hover {
    background: #f5c518;
    border-color: #f5c518;
    color: #1a1a1a;
  }
}

.no-sessions {
  text-align: center;
  padding: 80px 20px;
  color: #fff;
  font-size: 1.4rem;
  text-shadow: 0 2px 8px rgba(0,0,0,0.6);
}
