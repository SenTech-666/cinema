tsximport { Routes, Route } from 'react-router-dom';
import Layout from '../components/Layout/Layout';
import Home from '../pages/Guest/Home';
import Hall from '../pages/Guest/Hall/Hall';
import Booking from '../pages/Guest/Booking/Booking';
const Router = () => {
  return (
    <Routes>      <Route path="/" element={<Layout />}>
        <Route index element={<Home />} />
        <Route path="hall/:sessionId" element={<Hall />} />
        <Route path="booking" element={<Booking />} />
        <Route path="admin" element={<div>Админ-панель (в разработке)</div>} />
        <Route path="*" element={<div>404 — Страница не найдена</div>} />
      </Route></Routes>  );
};
export default Router;
Замени полностью src/components/HallScheme/HallScheme.tsx
tsximport { useState } from 'react';
import { Seat } from '../../types';
import './HallScheme.scss';
interface HallSchemeProps {
  onSeatsChange: (seats: Seat[]) => void;
}
const HallScheme = ({ onSeatsChange }: HallSchemeProps) => {
  const [selectedSeats, setSelectedSeats] = useState<Seat[]>([]);
  // Мок данных зала
  const seats: Seat[] = Array.from({ length: 8 }, (*, rowIndex) =>
    Array.from({ length: 12 }, (*, seatIndex) => ({
      id: $  {rowIndex + 1}-  ${seatIndex + 1},
      row: rowIndex + 1,
      number: seatIndex + 1,
      type: (rowIndex === 2 || rowIndex === 5) ? 'vip' : 'standard',
      status: Math.random() > 0.75 ? 'occupied' : 'free',
    }))
  ).flat();
  const toggleSeat = (seat: Seat) => {
    let newSelected: Seat[];
   
    if (selectedSeats.some(s => s.id === seat.id)) {
      newSelected = selectedSeats.filter(s => s.id !== seat.id);
    } else {
      newSelected = [...selectedSeats, seat];
    }
   
    setSelectedSeats(newSelected);
    onSeatsChange(newSelected);
  };
  return (
    <div className="hall-scheme"><div className="hall-scheme__screen">ЭКРАН</div><div className="hall-scheme__seats">        {seats.map((seat) => {
          const isSelected = selectedSeats.some(s => s.id === seat.id);
          return (
            <button
              key={seat.id}
              className={seat seat--$  {seat.type} seat--  ${seat.status} ${isSelected ? 'seat--selected' : ''}}
              onClick={() => toggleSeat(seat)}
              disabled={seat.status === 'occupied'}
            >
              {seat.number}
            </button>          );
        })}
      </div><div className="hall-scheme__legend"><div className="legend-item"><span className="seat seat--standard seat--free"></span><span>Обычное (250 ₽)</span></div><div className="legend-item"><span className="seat seat--vip seat--free"></span><span>VIP (350 ₽)</span></div><div className="legend-item"><span className="seat seat--occupied"></span><span>Занято</span></div><div className="legend-item"><span className="seat seat--selected"></span><span>Выбрано</span></div></div></div>  );
};
export default HallScheme;
Замени src/pages/Guest/Hall/Hall.tsx
tsximport { useState } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import HallScheme from '../../components/HallScheme/HallScheme';
import { Seat } from '../../types';
import './Hall.scss';
const Hall = () => {
  const { sessionId } = useParams();
  const navigate = useNavigate();
  const [selectedSeats, setSelectedSeats] = useState<Seat[]>([]);
  const STANDARD_PRICE = 250;
  const VIP_PRICE = 350;
  const totalPrice = selectedSeats.reduce((sum, seat) =>
    sum + (seat.type === 'vip' ? VIP_PRICE : STANDARD_PRICE), 0);
  const handleSeatsChange = (seats: Seat[]) => {
    setSelectedSeats(seats);
  };
  const handleBook = () => {
    if (selectedSeats.length === 0) return;
    navigate('/booking', {
      state: {
        sessionId: sessionId || '',
        movieTitle: "Звёздные войны XXIII: Атака клонов",
        time: "18:30",
        hall: "1",
        date: "Сегодня",
        selectedSeats,
        totalPrice
      }
    });
  };
  return (
    <div className="hall-page"><div className="container py-5"><div className="hall-page__info text-center mb-5"><h1>Звёздные войны XXIII: Атака клонов</h1><p>Начало сеанса: <strong>18:30</strong> • Зал 1 • {sessionId}</p></div><div className="hall-page__content mb-5"><HallScheme onSeatsChange={handleSeatsChange} /></div><div className="hall-page__actions text-center"><div className="selected-info fs-4 mb-4">            Выбрано мест: <strong>{selectedSeats.length}</strong> •
            Сумма: <strong>{totalPrice} ₽</strong></div>         
          <button
            className="btn btn-success btn-lg px-5"
            onClick={handleBook}
            disabled={selectedSeats.length === 0}
          >
            ЗАБРОНИРОВАТЬ
          </button></div></div></div>  );
};
export default Hall;
