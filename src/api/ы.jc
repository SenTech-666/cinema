src/components/HallScheme/HallScheme.tsx
tsximport { useState } from 'react';
import './HallScheme.scss';
interface Seat {
  id: string;
  row: number;
  number: number;
  type: 'standard' | 'vip';
  status: 'free' | 'occupied' | 'selected';
}
const HallScheme = () => {
  const [selectedSeats, setSelectedSeats] = useState<string[]>([]);
  // Мок данных для зала (как на макете)
  const seats: Seat[] = Array.from({ length: 8 }, (*, rowIndex) =>
    Array.from({ length: 12 }, (*, seatIndex) => ({
      id: $  {rowIndex + 1}-  ${seatIndex + 1},
      row: rowIndex + 1,
      number: seatIndex + 1,
      type: (rowIndex === 2 || rowIndex === 5) ? 'vip' : 'standard', // VIP в середине
      status: Math.random() > 0.7 ? 'occupied' : 'free'
    }))
  ).flat();
  const toggleSeat = (seatId: string) => {
    if (selectedSeats.includes(seatId)) {
      setSelectedSeats(selectedSeats.filter(id => id !== seatId));
    } else {
      setSelectedSeats([...selectedSeats, seatId]);
    }
  };
  return (
    <div className="hall-scheme"><div className="hall-scheme__screen">ЭКРАН</div><div className="hall-scheme__seats">        {seats.map((seat) => {
          const isSelected = selectedSeats.includes(seat.id);
          return (
            <button
              key={seat.id}
              className={seat seat--$  {seat.type} seat--  ${seat.status} ${isSelected ? 'seat--selected' : ''}}
              onClick={() => toggleSeat(seat.id)}
              disabled={seat.status === 'occupied'}
            >
              {seat.number}
            </button>          );
        })}
      </div><div className="hall-scheme__legend"><div className="legend-item"><span className="seat seat--standard seat--free"></span><span>Свободно (250 ₽)</span></div><div className="legend-item"><span className="seat seat--vip seat--free"></span><span>Свободно VIP (350 ₽)</span></div><div className="legend-item"><span className="seat seat--occupied"></span><span>Занято</span></div><div className="legend-item"><span className="seat seat--selected"></span><span>Выбрано</span></div></div></div>  );
};
export default HallScheme;
