Шаг 1: Замени полностью src/pages/Guest/Hall/Hall.tsx
tsxКопироватьimport { useState } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import Header from '../../../components/Header/Header';
import HallScheme from '../../components/HallScheme/HallScheme';
import { Seat } from '@/types';
import './Hall.scss';

const Hall = () => {
  const { sessionId } = useParams();
  const navigate = useNavigate();

  const [selectedSeats, setSelectedSeats] = useState<Seat[]>([]);

  const STANDARD_PRICE = 250;
  const VIP_PRICE = 350;

  const totalPrice = selectedSeats.reduce((sum, seat) => 
    sum + (seat.type === 'vip' ? VIP_PRICE : STANDARD_PRICE), 0);

  const handleSeatsChange = (seats: Seat[]) => {
    setSelectedSeats(seats);
  };

  const handleBook = () => {
    if (selectedSeats.length === 0) return;
    
    navigate('/booking', {
      state: {
        sessionId: sessionId || '',
        movieTitle: "Звёздные войны XXIII: Атака клонов",
        time: "18:30",
        hall: "1",
        date: "Сегодня",
        selectedSeats,
        totalPrice
      }
    });
  };

  return (
    <>
      <Header variant="transparent" />

      <div className="hall-page">
        <div className="hall-page__background">
          <div className="hall-page__content">

            {/* Заголовок */}
            <div className="hall-page__header">
              <div className="logo-big">ИДЁМ<span className="logo-big__v">В</span>КИНО</div>
            </div>

            {/* Информация о сеансе */}
            <div className="hall-page__info">
              <h1 className="hall-page__title">Звёздные войны XXIII: Атака клонов</h1>
              <p className="hall-page__details">
                Начало сеанса: <strong>18:30</strong> • Зал 1
              </p>
            </div>

            {/* Схема зала */}
            <div className="hall-scheme-wrapper">
              <HallScheme onSeatsChange={handleSeatsChange} />
            </div>

            {/* Кнопка бронирования */}
            <div className="hall-page__actions">
              <button
                className="btn btn-book"
                onClick={handleBook}
                disabled={selectedSeats.length === 0}
              >
                ЗАБРОНИРОВАТЬ
              </button>
            </div>

          </div>
        </div>
      </div>
    </>
  );
};

export default Hall;
Шаг 2: Замени полностью src/components/HallScheme/HallScheme.tsx
tsxКопироватьimport { useState } from 'react';
import { Seat } from '@/types';
import './HallScheme.scss';

interface HallSchemeProps {
  onSeatsChange: (seats: Seat[]) => void;
}

const HallScheme = ({ onSeatsChange }: HallSchemeProps) => {
  const [selectedSeats, setSelectedSeats] = useState<Seat[]>([]);

  // Мок данных зала (в будущем придёт из админки)
  const seats: Seat[] = Array.from({ length: 8 }, (_, rowIndex) =>
    Array.from({ length: 12 }, (_, seatIndex) => ({
      id: `${rowIndex + 1}-${seatIndex + 1}`,
      row: rowIndex + 1,
      number: seatIndex + 1,
      type: (rowIndex === 2 || rowIndex === 5) ? 'vip' : 'standard' as const,
      status: Math.random() > 0.75 ? 'occupied' : 'free' as const,
    }))
  ).flat();

  const toggleSeat = (seat: Seat) => {
    let newSelected: Seat[];
    if (selectedSeats.some(s => s.id === seat.id)) {
      newSelected = selectedSeats.filter(s => s.id !== seat.id);
    } else {
      newSelected = [...selectedSeats, seat];
    }
    setSelectedSeats(newSelected);
    onSeatsChange(newSelected);
  };

  return (
    <div className="hall-scheme">
      <div className="hall-scheme__screen">ЭКРАН</div>

      <div className="hall-scheme__seats">
        {seats.map((seat) => {
          const isSelected = selectedSeats.some(s => s.id === seat.id);
          return (
            <button
              key={seat.id}
              className={`seat seat--${seat.type} seat--${seat.status} ${isSelected ? 'seat--selected' : ''}`}
              onClick={() => toggleSeat(seat)}
              disabled={seat.status === 'occupied'}
            >
              {seat.number}
            </button>
          );
        })}
      </div>

      {/* Легенда */}
      <div className="hall-scheme__legend">
        <div className="legend-item">
          <span className="seat seat--standard seat--free"></span>
          <span>Свободно (250 ₽)</span>
        </div>
        <div className="legend-item">
          <span className="seat seat--vip seat--free"></span>
          <span>Свободно VIP (350 ₽)</span>
        </div>
        <div className="legend-item">
          <span className="seat seat--occupied"></span>
          <span>Занято</span>
        </div>
        <div className="legend-item">
          <span className="seat seat--selected"></span>
          <span>Выбрано</span>
        </div>
      </div>
    </div>
  );
};

